generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
}

model Session {
  id         String   @id
  name       String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  clicks     Click[]
}

model Click {
  id         String   @id
  x          Float
  y          Float
  intensity  Int      @default(1)
  session_id String
  created_at DateTime @default(now())
  session    Session  @relation(fields: [session_id], references: [id], onDelete: Cascade)
}